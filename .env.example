# =========================
# Core App
# =========================
APP_NAME=TimeManager Pro
APP_ENV=development
APP_DEBUG=true

# =========================
# Server
# =========================
APP_HOST=127.0.0.1
APP_PORT=8000
WEBAPP_BASE_URL=http://127.0.0.1:8000

# =========================
# Telegram
# =========================
BOT_TOKEN=replace_me
TELEGRAM_INITDATA_MAX_AGE=900

# =========================
# Database
# =========================
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=time_manager_pro

# =========================
# App Limits
# =========================
MAX_TITLE_LEN=200
MAX_NOTE_LEN=2000
MAX_EVENTS_PER_USER=500
RATE_LIMIT_COUNT=30

# =========================
# Reminder Worker
# =========================
REMINDER_BATCH_SIZE=50
STALE_PROCESSING_SECS=300
REMINDER_POLL_INTERVAL_SECS=30
DEFAULT_REMINDER_HOUR=9

# =========================
# Logging
# =========================
LOG_LEVEL=INFO
TELEGRAM_INITDATA_FUTURE_SKEW=60