# ══════════════════════════════════════════════════════
# TimeManager Pro — .env.example
# Copy to .env and fill in real values.
# ✅ FIX: APP_DEBUG defaults to false (was: true — security risk)
# ══════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────
APP_NAME=TimeManager Pro
APP_ENV=production          # development | staging | production
APP_DEBUG=false             # ← NEVER set to true in production
APP_HOST=127.0.0.1
APP_PORT=8000
WEBAPP_BASE_URL=https://your-domain.com

# ── Telegram Bot ─────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# How long (seconds) a Telegram initData token is valid
TELEGRAM_INITDATA_MAX_AGE=900
# Allow for slight clock skew between Telegram servers and your server
TELEGRAM_INITDATA_FUTURE_SKEW=60

# ── MongoDB ──────────────────────────────────────────
# For local development: mongodb://127.0.0.1:27017
# For production: use MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=time_manager_pro

# ── Limits ───────────────────────────────────────────
MAX_TITLE_LEN=200
MAX_NOTE_LEN=2000
MAX_EVENTS_PER_USER=500

# ── Rate Limiting ─────────────────────────────────────
# Max requests per user per 60-second window
RATE_LIMIT_COUNT=30

# ── Reminder Worker ───────────────────────────────────
# How many reminders to process in one worker cycle
REMINDER_BATCH_SIZE=50
# Seconds before a "processing" reminder is considered stale and re-queued
STALE_PROCESSING_SECS=300
# How often (seconds) the worker polls for due reminders
REMINDER_POLL_INTERVAL_SECS=30
# Default hour of day (0-23) for reminder notifications
DEFAULT_REMINDER_HOUR=9

# ── Logging ───────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
