[Unit]
Description=TimeManager Pro Reminder Worker
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/time-manager-pro
EnvironmentFile=/opt/time-manager-pro/.env
ExecStart=/opt/time-manager-pro/.venv/bin/python -m worker.reminder_worker
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target